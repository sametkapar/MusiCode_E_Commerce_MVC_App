@model MusiCodeWebApp.Models.Product
@{
    ViewBag.Title = "Ürün Ekle";
    Layout = "~/Areas/ManagerPanel/Views/Shared/_LayoutPage1.cshtml";
}
@section styles
{
    <link href="~/Areas/ManagerPanel/Assets/css/FormStyle.css" rel="stylesheet" />
}
<div class="pagetitle">
    <h2>Ürün Ekle</h2>
</div>
<div class="formContainer">
    @using (Html.BeginForm())
    {
        if (ViewBag.mesaj != null)
        {
            <label class="validationmesage">@ViewBag.mesaj</label>
        }
        <div class="row">
            <label>İsim</label>
            @Html.EditorFor(x => x.Name, new { htmlAttributes = new { @class = "textbox" } })
            @Html.ValidationMessageFor(x => x.Name, "", new { @class = "validationmesage" })
        </div>
        <div class="row">
            <label>Kategory İsmi</label>
            @Html.DropDownList("Category_ID", null, htmlAttributes: new { @class = "textbox" })
        </div>
        <div class="row">
            <label>Marka İsmi</label>
            @Html.DropDownList("Brand_ID", null, htmlAttributes: new { @class = "textbox" })
        </div>
        <div class="row">
            <label>Fiyat</label>
            @Html.EditorFor(x => x.UnitPrice, new { htmlAttributes = new { @class = "textbox" } })
            @Html.ValidationMessageFor(x => x.UnitPrice, "", new { @class = "validationmesage" })
        </div>
        <div class="row">
            <label>Stok</label>
            @Html.EditorFor(x => x.UnitsInStock, new { htmlAttributes = new { @class = "textbox" } })
            @Html.ValidationMessageFor(x => x.UnitsInStock, "", new { @class = "validationmesage" })
        </div>
        <div class="row">
            @Html.EditorFor(x => x.IsActive, new { htmlAttributes = new { @id = "isActive" } })
            <label for="isActive"> Aktif Ürün</label>
        </div>
        <div class="row">
            <button type="submit" class="formbutton">Ürün Ekle</button>
        </div>

    }
</div>


